# Backend-on-VPS config (FE on Vercel). Copy to `.env` in this directory and fill
# in real values. Compose auto-loads `.env` for ${VAR} substitution when you run
# `docker compose` from here. NEVER commit the real .env.

# ── API domain (this VPS) ─────────────────────────────────────────────────────
# DNS A/AAAA record for this subdomain must point at the VPS IP; ports 80 + 443
# must be reachable so Caddy can obtain Let's Encrypt certs automatically.
API_DOMAIN=api.yourdomain.com
ACME_EMAIL=you@example.com

# ── Frontend origin(s) allowed by CORS ────────────────────────────────────────
# Your Vercel production URL and/or custom domain. Comma-separate multiple.
# Exact origins only: scheme + host, NO trailing slash, NO path.
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=monopoly
MONGO_ROOT_PASSWORD=change_me_long_random_value
MONGODB_DB=monopoly

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_long_random_value

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET_KEY=change_me_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App / logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Game rules (optional overrides) ───────────────────────────────────────────
GAME_STARTING_BALANCE=1500
GO_SALARY=200
JAIL_FINE=50
